# Proxmox integration-test credentials — TEMPLATE.
#
# Copy this file to ".pvetest.env" (same folder) and fill in your values, then:
#   go test ./internal/hypervisor/ -run TestProxmoxCreateAndAttachISO -v
#
# Without PVE_URL the integration test is skipped, so CI stays green.
# The real ".pvetest.env" is gitignored and must NEVER be committed.
#
# Keep comments on their OWN lines (above each key). Inline "value # comment"
# is tolerated by the loader, but own-line comments avoid any ambiguity.

# --- Connection ---

# Full API base URL.
PVE_URL=https://192.168.1.10:8006/api2/json

# PVE node name — exactly as shown in the left tree of the web UI.
PVE_NODE=proxmox

# Storage for VM disks.
PVE_STORAGE=local-lvm

# Storage that accepts ISO content (often "local").
PVE_ISO_STORAGE=local

# Network bridge for the VM NIC.
PVE_BRIDGE=vmbr0

# Proxmox ships a self-signed cert; true skips TLS verification.
PVE_INSECURE=true

# --- Auth: use EITHER user/password (recommended for ISO upload) ... ---
PVE_USER=root@pam
PVE_PASSWORD=changeme

# --- ... OR an API token (token auth has known multipart-upload quirks) ---
# PVE_TOKEN_ID=root@pam!autodeploy
# PVE_TOKEN_SECRET=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# --- Optional: point at a real small ISO instead of the generated placeholder ---
# PVE_TEST_ISO=C:\path\to\some-small.iso
